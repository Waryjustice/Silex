# Required environment variables for inference.py

# API endpoint for LLM inference (with default)
API_BASE_URL="https://router.huggingface.co/v1"

# Model name to use for inference (with default)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Hugging Face API token (NO DEFAULT - must be provided)
HF_TOKEN=your_hf_token_here

# Optional: for local Docker testing
# LOCAL_IMAGE_NAME=data-cleaning-env:latest
